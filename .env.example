# --- Anmelde-Modus ---
# LOGIN_MODE legt fest, wie man sich anmeldet:
#   demo   -> Person per Klick auswählen (kein Slack nötig; gut zum Ausprobieren)
#   slack  -> echtes "Mit Slack anmelden" (braucht die SLACK_-Werte unten)
#   (leer) -> Standard: demo
LOGIN_MODE=demo

# Für LOGIN_MODE=slack:
# 1. Auf api.slack.com/apps eine App anlegen.
# 2. Unter "OAuth & Permissions" als Redirect URL eintragen:
#       http://localhost:5173/auth/slack/callback
# 3. Unter "User Token Scopes" hinzufügen: openid, profile, email
# 4. Client ID und Client Secret aus "Basic Information" hier eintragen.
# 5. Diese Datei als ".env" (ohne .example) speichern und Server neu starten.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5173/auth/slack/callback

# Geheimnis zum Signieren der Login-Cookies.
# Erzeugen mit:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Datenbank-Wahl ---
# DB_MODE steuert, welche Datenbank benutzt wird:
#   local  -> immer die lokale Datei local.db (schnell, offline; ideal zum Entwickeln)
#   turso  -> die gehostete Turso-Cloud-Datenbank (braucht die zwei Werte unten)
#   (leer) -> automatisch: Turso, wenn unten Zugangsdaten stehen, sonst lokal
# Praktisch: Zugangsdaten unten stehen lassen UND lokal trotzdem schnell arbeiten,
# indem du hier "local" setzt. Auf Vercel DB_MODE leer lassen -> nutzt Turso.
# Hinweis: Um gezielt die CLOUD-DB anzupassen/zu befüllen:
#   DB_MODE=turso npm run db:push     bzw.   DB_MODE=turso npm run db:seed
DB_MODE=

# --- Nur fürs Hosting in der Cloud (z. B. Vercel/Netlify) ---
# Eine kostenlose Turso-Datenbank anlegen (turso.tech) und hier die zwei Werte
# eintragen. Danach EINMAL "DB_MODE=turso npm run db:push" ausführen, damit die
# Tabellen in der Cloud-Datenbank entstehen.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Spielregeln über Umgebungs-Variablen (für den Produktivbetrieb) ---
# Im DEMO-Modus stellst du alle Werte bequem in der App ein (Einstellungen).
# Im SLACK-Modus sind die Felder in der App gesperrt – die Werte kommen dann NUR
# von hier (Vorrang: LN_-Variable > Datenbank > Standard). Leere Variablen werden
# ignoriert. Name = "LN_" + Einstellungs-Schlüssel in GROSSBUCHSTABEN. Beispiele:
# LN_TICKETSPERWEEK=5            # Fahrscheine pro Woche
# LN_POINTSNEWSTRECKE=15        # Punkte für eine neue Strecke
# LN_POINTSGIVETICKET=8         # Punkte fürs Verschenken
# LN_POINTSRECEIVETICKET=5      # Punkte fürs Erhalten
# LN_POINTSANSWER=5             # Punkte für die Tagesfrage
# LN_POINTSLIECORRECT=10        # Punkte für eine enttarnte Lüge
# LN_LEVELKLEINSTADT=5          # Linien bis Kleinstadt
# LN_LEVELGROSSSTADT=15         # Linien bis Großstadt
# LN_LEVELMETROPOLE=30          # Linien bis Metropole
# LN_DECOBANK=20  LN_DECOLAMPE=40  LN_DECOCAFE=70  LN_DECOTRAM=100   # Werkstatt-Kosten
# LN_FIRMENWERTE=Füreinander da, Software mit Herz, Gemeinsam wegweisend, Tüftlergeist, Fahrgast im Blick
# LN_ABTEILUNGEN=Produkt, Entwicklung, Beratung, Support, Design, Verwaltung   # Abteilungen (= Stadtviertel)
